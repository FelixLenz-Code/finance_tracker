# --- Datenbank ---
DATABASE_URL="postgresql://tracker:tracker@localhost:5432/tracker?schema=public"

# --- App ---
APP_URL="http://localhost:3000"
# Geheimer Schlüssel für Session-/Token-Hashing & TOTP-Secret-Verschlüsselung.
# Erzeugen mit: openssl rand -base64 48
AUTH_SECRET="change-me-please-generate-a-long-random-secret"

# --- Twelve Data (nur symbol_search fürs Auto-Fill) ---
# Kostenloser Key: https://twelvedata.com/
TWELVEDATA_API_KEY=""

# --- E-Mail (optional: Verifizierung & Passwort-Reset) ---
# Wenn SMTP_HOST leer ist, werden Mails nur in die Server-Logs geschrieben (Dev),
# und neu angelegte Nutzer gelten als verifiziert.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Trade Tracker <no-reply@example.com>"

# --- 2FA ---
TOTP_ISSUER="Trade Tracker"
